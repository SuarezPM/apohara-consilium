{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "devCommand": "npm run dev",
  "github": {
    "silent": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/verify", "destination": "/consilium/verify", "permanent": false },
    { "source": "/compliance", "destination": "/consilium/compliance", "permanent": false },
    { "source": "/about", "destination": "/consilium/about", "permanent": false },
    { "source": "/jury-guide", "destination": "/consilium/about", "permanent": false },
    { "source": "/try-live", "destination": "/consilium/verify", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/consilium",
      "destination": "https://apohara-consilium.vercel.app/"
    },
    {
      "source": "/consilium/",
      "destination": "https://apohara-consilium.vercel.app/"
    },
    {
      "source": "/consilium/:path*",
      "destination": "https://apohara-consilium.vercel.app/:path*"
    },
    {
      "source": "/((?!assets/|.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://api.apohara.dev",
    "VITE_MOCK_API": "false"
  }
}
