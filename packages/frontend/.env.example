# Frontend environment template for Apohara Inti.
# Copy to `.env.local` and edit for your local dev setup.

# Backend base URL (US-006 FastAPI). Default for dev.
VITE_API_URL=http://localhost:8000

# Enable mock mode so the UI works without backend running.
# Set to "true" to use canned 9-attacker responses.
VITE_MOCK_API=true
